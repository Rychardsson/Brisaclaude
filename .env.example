# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente para o Docker Compose (BRISA)
# Copie este arquivo para .env e ajuste os valores antes de rodar.
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados PostgreSQL
POSTGRES_PASSWORD=130680

# JWT – troque por uma string longa e aleatória em produção!
JWT_SECRET=brisa-super-secret-key-change-in-production

# URL pública da API (usada no build do frontend)
# Em produção, substitua por seu domínio real (ex.: https://api.brisa.com.br/api)
VITE_API_BASE_URL=http://localhost:8082/api

# E-mail (opcional – deixe em branco para desabilitar envio de e-mails)
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_FROM=

# Cron de automação de carreiras (padrão: a cada 6 horas)
CAREER_AUTOMATION_CRON=0 0 */6 * * *
